# ============================================================
# FlyEasy OTA Portal - Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to source control
# ============================================================

# ----- Application -----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# ----- Azure SQL Server / SQL Server -----
SQL_SERVER=your-server.database.windows.net
SQL_DATABASE=flyeasy
SQL_USER=your-sql-user
SQL_PASSWORD=your-sql-password
SQL_PORT=1433
# Set to true for Azure SQL, false for local SQL Server
SQL_ENCRYPT=true

# ----- Amadeus GDS (Flight Search) -----
# Get from: https://developers.amadeus.com
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_HOSTNAME=test
# Use 'production' when going live

# ----- Razorpay (Payments) -----
# Get from: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# ----- SMTP Email (Ticket Notifications) -----
# Recommended: Use Brevo (formerly Sendinblue) free tier
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-email@example.com
SMTP_PASS=your-brevo-smtp-key

# ----- Security -----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ----- Rate Limiting (optional - Redis) -----
# REDIS_URL=redis://localhost:6379

# ----- Monitoring (optional) -----
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
